{
  "manifest_version": 3,
  "name": "Doc Reception Macro",
  "version": "1.1.0",
  "description": "문서 접수 반복 작업용 크롬 확장",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}